:root {
    --primary-blue: #4A8CFF;
    --glass-bg: rgba(255, 255, 255, 0.08);
    --glass-border: rgba(255, 255, 255, 0.12);
    --accent-cyan: #00d4ff;
    --accent-orange: #ff6b35;
}

body {
    font-family: 'Outfit', 'Segoe UI', sans-serif;
    margin: 0;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    overflow-x: hidden;
    transition: background 1.5s cubic-bezier(0.4, 0, 0.2, 1);
    color: white;
}

.weather-bg-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
}

.weather-bg-container::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 50% 50%, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.4) 100%);
    z-index: 2;
}

.navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    padding: 16px 32px;
    background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, transparent 100%);
    backdrop-filter: blur(10px);
}

.header-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    transition: transform 0.3s ease;
}

.header-logo:hover {
    transform: scale(1.02);
}

.mini-logo {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

.logo-text {
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: -0.5px;
    background: linear-gradient(135deg, #fff 0%, rgba(255,255,255,0.8) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.main-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 120px 20px 60px;
    min-height: 100vh;
}

.search-group {
    display: flex;
    align-items: center;
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: 50px;
    padding: 8px;
    width: 100%;
    max-width: 500px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    transition: all 0.3s ease;
}

.search-group:focus-within {
    transform: scale(1.02);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.3);
}

.search-group input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 16px 24px;
    font-size: 1.1rem;
    color: white;
    font-family: 'Outfit', sans-serif;
}

.search-group input::placeholder {
    color: rgba(255, 255, 255, 0.5);
}

.search-group input:focus {
    outline: none;
}

.search-group button {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: none;
    background: linear-gradient(135deg, var(--accent-cyan), #0099cc);
    color: white;
    font-size: 1.2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
}

.search-group button:hover {
    transform: scale(1.1);
    box-shadow: 0 8px 24px rgba(0, 212, 255, 0.4);
}

.auth-buttons {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-left: auto;
}

.auth-btn {
    padding: 10px 24px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: var(--glass-bg);
    backdrop-filter: blur(10px);
    color: white;
    border-radius: 30px;
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.3s ease;
}

.auth-btn:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.4);
    transform: translateY(-2px);
}

.auth-btn-primary {
    background: linear-gradient(135deg, var(--accent-cyan), #0099cc);
    border-color: transparent;
}

.auth-btn-primary:hover {
    background: linear-gradient(135deg, #00e5ff, #00aadd);
    box-shadow: 0 8px 24px rgba(0, 212, 255, 0.3);
}

.user-menu {
    position: relative;
}

.user-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    background: linear-gradient(135deg, rgba(255,255,255,0.15), rgba(255,255,255,0.05));
    border: 1px solid var(--glass-border);
    border-radius: 30px;
    color: white;
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
}

.user-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
}

.user-dropdown {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    background: rgba(10, 20, 40, 0.95);
    backdrop-filter: blur(20px);
    border-radius: 16px;
    overflow: hidden;
    display: none;
    min-width: 180px;
    border: 1px solid var(--glass-border);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
    animation: dropdownFade 0.2s ease;
}

@keyframes dropdownFade {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
}

.user-dropdown.active {
    display: block;
}

.logout-btn {
    width: 100%;
    padding: 14px 24px;
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.8);
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    text-align: left;
    transition: all 0.3s ease;
}

.logout-btn:hover {
    background: rgba(255, 107, 53, 0.2);
    color: var(--accent-orange);
}

.auth-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 10, 30, 0.8);
    z-index: 1000;
    justify-content: center;
    align-items: center;
    backdrop-filter: blur(8px);
    animation: modalFadeIn 0.3s ease;
}

@keyframes modalFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.auth-modal.active {
    display: flex;
}

.auth-modal-content {
    background: linear-gradient(145deg, rgba(20, 40, 80, 0.9), rgba(10, 20, 40, 0.95);
    padding: 48px;
    border-radius: 24px;
    width: 90%;
    max-width: 420px;
    position: relative;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.5), 0 0 0 1px var(--glass-border);
    border: 1px solid var(--glass-border);
    animation: modalSlideIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes modalSlideIn {
    from { opacity: 0; transform: translateY(30px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
}

.auth-close {
    position: absolute;
    top: 20px;
    right: 24px;
    font-size: 28px;
    color: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: all 0.3s ease;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
}

.auth-close:hover {
    color: white;
    background: rgba(255, 255, 255, 0.1);
}

.auth-form h2 {
    margin: 0 0 32px;
    text-align: center;
    font-weight: 700;
    font-size: 1.8rem;
    background: linear-gradient(135deg, #fff 0%, rgba(255,255,255,0.8) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.form-group {
    margin-bottom: 24px;
}

.form-group input {
    width: 100%;
    padding: 16px 20px;
    border: 1px solid var(--glass-border);
    border-radius: 14px;
    background: var(--glass-bg);
    color: white;
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    box-sizing: border-box;
    transition: all 0.3s ease;
}

.form-group input::placeholder {
    color: rgba(255, 255, 255, 0.4);
}

.form-group input:focus {
    outline: none;
    border-color: var(--accent-cyan);
    background: rgba(0, 212, 255, 0.05);
    box-shadow: 0 0 0 3px rgba(0, 212, 255, 0.1);
}

.auth-submit {
    width: 100%;
    padding: 16px;
    background: linear-gradient(135deg, var(--accent-cyan), #0099cc);
    color: white;
    border: none;
    border-radius: 14px;
    font-family: 'Outfit', sans-serif;
    font-size: 1.05rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 8px;
}

.auth-submit:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 212, 255, 0.35);
}

.auth-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
}

.auth-switch {
    text-align: center;
    margin-top: 24px;
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.95rem;
}

.auth-switch button {
    background: none;
    border: none;
    color: var(--accent-cyan);
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0;
    margin-left: 6px;
    transition: all 0.3s ease;
}

.auth-switch button:hover {
    color: #00e5ff;
    text-shadow: 0 0 10px rgba(0, 212, 255, 0.5);
}

.auth-message {
    margin-top: 20px;
    padding: 14px 18px;
    border-radius: 12px;
    text-align: center;
    display: none;
    font-size: 0.9rem;
    animation: messageSlide 0.3s ease;
}

@keyframes messageSlide {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
}

.auth-message.success {
    display: block;
    background: rgba(46, 204, 113, 0.15);
    border: 1px solid rgba(46, 204, 113, 0.3);
    color: #2ecc71;
}

.auth-message.error {
    display: block;
    background: rgba(231, 76, 60, 0.15);
    border: 1px solid rgba(231, 76, 60, 0.3);
    color: #e74c3c;
}

.auth-message.info {
    display: block;
    background: rgba(0, 212, 255, 0.15);
    border: 1px solid rgba(0, 212, 255, 0.3);
    color: var(--accent-cyan);
}

.weather-card {
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    padding: 32px;
    margin-top: 32px;
    width: 90%;
    max-width: 500px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    animation: cardFadeIn 0.5s ease;
}

@keyframes cardFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

.city-name {
    font-size: 1.8rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 8px;
}

.desc {
    text-align: center;
    font-size: 1.1rem;
    opacity: 0.8;
    margin-bottom: 24px;
}

.temp-container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 16px;
}

.weather-icon {
    width: 100px;
    height: 100px;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.3));
}

.temp-main {
    font-size: 4rem;
    font-weight: 700;
}

.feels-like {
    text-align: center;
    font-size: 0.95rem;
    opacity: 0.7;
    margin-bottom: 24px;
}

.details-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
}

.detail-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 16px;
    background: var(--glass-bg);
    border-radius: 16px;
    border: 1px solid var(--glass-border);
}

.detail-item i {
    font-size: 1.5rem;
}

.icon-blue { color: var(--accent-cyan); }
.icon-gray { color: rgba(255, 255, 255, 0.6); }

.detail-item .label {
    font-size: 0.8rem;
    opacity: 0.6;
}

.detail-item .value {
    font-size: 1.1rem;
    font-weight: 600;
}

.error {
    display: none;
    background: rgba(231, 76, 60, 0.2);
    border: 1px solid rgba(231, 76, 60, 0.4);
    color: #e74c3c;
    padding: 16px 24px;
    border-radius: 12px;
    margin-top: 24px;
    font-size: 0.95rem;
}

.forecast-container {
    width: 90%;
    max-width: 800px;
    margin-top: 32px;
}

.forecast-container h3 {
    text-align: center;
    font-size: 1.3rem;
    margin-bottom: 24px;
    font-weight: 600;
}

.forecast-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 16px;
}

.forecast-card {
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    padding: 20px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
}

.forecast-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.2);
    background: rgba(255, 255, 255, 0.12);
}

.forecast-date {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: var(--accent-cyan);
}

.forecast-icon {
    width: 60px;
    height: 60px;
    margin: 8px 0;
}

.forecast-temp {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 4px;
}

.forecast-desc {
    font-size: 0.8rem;
    opacity: 0.7;
}

.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 10, 30, 0.85);
    z-index: 1000;
    justify-content: center;
    align-items: center;
    backdrop-filter: blur(8px);
}

.modal.active {
    display: flex;
    animation: modalFadeIn 0.3s ease;
}

.modal-content {
    background: linear-gradient(145deg, rgba(20, 40, 80, 0.95), rgba(10, 20, 40, 0.98));
    padding: 32px;
    border-radius: 24px;
    width: 90%;
    max-width: 500px;
    max-height: 80vh;
    overflow-y: auto;
    border: 1px solid var(--glass-border);
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.5);
    animation: modalSlideIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.modal-content .close {
    position: absolute;
    top: 20px;
    right: 24px;
    font-size: 28px;
    color: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: all 0.3s ease;
}

.modal-content .close:hover {
    color: white;
}

.modal h3 {
    text-align: center;
    margin-bottom: 24px;
    font-size: 1.3rem;
    color: var(--accent-cyan);
}

.modal-details {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.hourly-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background: var(--glass-bg);
    border-radius: 12px;
    border: 1px solid var(--glass-border);
}

.hourly-time {
    font-weight: 600;
    min-width: 60px;
    color: var(--accent-cyan);
}

.hourly-desc {
    flex: 1;
    font-size: 0.9rem;
    opacity: 0.8;
}

.hourly-temp {
    font-weight: 700;
    font-size: 1.1rem;
}

.map-container {
    width: 100%;
    max-width: 500px;
    height: 500px;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
}

.map-info {
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    padding: 24px;
    margin-top: 24px;
    width: 90%;
    max-width: 500px;
}

.map-status {
    text-align: center;
    font-size: 1.1rem;
    margin-bottom: 16px;
    color: var(--accent-cyan);
}

.map-weather {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
}

.map-weather-title {
    font-size: 0.9rem;
    opacity: 0.6;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
}

#homeLocationName {
    font-size: 1.4rem;
    font-weight: 700;
}

#homeLocalTime {
    font-size: 0.9rem;
    opacity: 0.7;
}

.map-btn {
    padding: 10px 20px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    color: white;
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    transition: all 0.3s ease;
}

.map-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
}

body.clear { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); }
body.clear::before { content: ''; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(ellipse at top, rgba(0,212,255,0.1) 0%, transparent 60%); pointer-events: none; z-index: 1; }

body.rain, body.thunderstorm { background: linear-gradient(135deg, #1a1a2e 0%, #0d1b2a 50%, #1b263b 100%); }
body.rain::before, body.thunderstorm::before { content: ''; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(ellipse at top, rgba(0,100,150,0.15) 0%, transparent 60%); pointer-events: none; z-index: 1; }

body.snow { background: linear-gradient(135deg, #2c3e50 0%, #34495e 50%, #5d6d7e 100%); }
body.snow::before { content: ''; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(ellipse at top, rgba(255,255,255,0.1) 0%, transparent 60%); pointer-events: none; z-index: 1; }

body.clouds { background: linear-gradient(135deg, #2c3e50 0%, #34495e 50%, #4a5a6a 100%); }
body.clouds::before { content: ''; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(ellipse at top, rgba(100,120,140,0.12) 0%, transparent 60%); pointer-events: none; z-index: 1; }

body.night { background: linear-gradient(135deg, #0a0a1a 0%, #1a1a2e 30%, #0d1b2a 70%, #1b263b 100%) !important; }
body.night::before { content: ''; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(ellipse at top, rgba(50,50,100,0.15) 0%, transparent 60%); pointer-events: none; z-index: 1; }

body.thunderstorm { background: linear-gradient(135deg, #0a0a1a 0%, #1a1a2e 30%, #0d1b2a 70%, #1b263b 100%); }

@keyframes rain-drop {
    0% { transform: translateY(-10vh) translateX(0); opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { transform: translateY(110vh) translateX(20px); opacity: 0; }
}

@keyframes snow-flake {
    0% { transform: translateY(-10vh) translateX(0) rotate(0deg); opacity: 0; }
    10% { opacity: 1; }
    50% { transform: translateY(50vh) translateX(30px) rotate(180deg); }
    90% { opacity: 1; }
    100% { transform: translateY(110vh) translateX(-20px) rotate(360deg); opacity: 0; }
}

@keyframes cloud-drift {
    0% { transform: translateX(-20%); }
    50% { transform: translateX(20%); }
    100% { transform: translateX(-20%); }
}

.rain-drop { position: absolute; background: linear-gradient(to bottom, transparent, rgba(0,212,255,0.6)); width: 2px; height: 20px; animation: rain-drop linear infinite; top: -20px; }
.snow-flake { position: absolute; background: white; border-radius: 50%; animation: snow-flake linear infinite; }
.cloud-particle { position: absolute; background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%); border-radius: 50%; animation: cloud-drift ease-in-out infinite; }

@media (max-width: 600px) {
    .navbar {
        padding: 12px 16px;
    }
    .logo-text {
        font-size: 1.4rem;
    }
    .auth-btn {
        padding: 8px 16px;
        font-size: 0.85rem;
    }
    .search-group {
        padding: 6px;
    }
    .search-group input {
        padding: 12px 16px;
        font-size: 1rem;
    }
    .search-group button {
        width: 48px;
        height: 48px;
    }
    .weather-card {
        padding: 24px 16px;
    }
    .temp-main {
        font-size: 3rem;
    }
    .details-grid {
        grid-template-columns: 1fr;
    }
    .forecast-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    .auth-modal-content {
        padding: 32px 24px;
    }
}